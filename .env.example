# Postgres
POSTGRES_USER=ecommerce_admin
POSTGRES_PASSWORD=SecurePass123!

# Redis
REDIS_PASSWORD=RedisSecure456!

# RabbitMQ
RABBITMQ_USER=rabbit_admin
RABBITMQ_PASSWORD=RabbitSecure789!

# Keycloak
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=KeycloakAdmin123!

# Seq
SEQ_ADMIN_PASSWORD=SeqAdmin456!

# Stripe (Payment Service)
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# SendGrid (Notification Service)
SENDGRID_API_KEY=SG.your_key_here
SENDGRID_FROM_EMAIL=noreply@ecommerce.com

# Twilio (Notification Service)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_PHONE=+1234567890

# Firebase (Notification Service)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_SERVICE_ACCOUNT_KEY=./infra/firebase/service-account.json

# Azure Blob Storage (Media Service)
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=youraccount;AccountKey=yourkey;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER_NAME=ecommerce-media
AZURE_CDN_BASE_URL=https://yourcdn.azureedge.net

