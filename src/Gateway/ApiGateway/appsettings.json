{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning"
      }
    }
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/ecommerce",
    "Audience": "ecommerce-backend",
    "RequireHttpsMetadata": false
  },
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },
  "AllowedOrigins": [
    "http://localhost:3000",
    "http://localhost:4200"
  ],
  "ReverseProxy": {
    "Routes": {
      "auth-route":       { "ClusterId": "identity-cluster",  "Match": { "Path": "/api/auth/{**catch-all}" } },
      "users-route":      { "ClusterId": "identity-cluster",  "Match": { "Path": "/api/users/{**catch-all}" } },
      "products-route":   { "ClusterId": "catalog-cluster",   "Match": { "Path": "/api/products/{**catch-all}" } },
      "categories-route": { "ClusterId": "catalog-cluster",   "Match": { "Path": "/api/categories/{**catch-all}" } },
      "orders-route":     { "ClusterId": "order-cluster",     "Match": { "Path": "/api/orders/{**catch-all}" } },
      "payments-route":   { "ClusterId": "payment-cluster",   "Match": { "Path": "/api/payments/{**catch-all}" } },
      "cart-route":       { "ClusterId": "cart-cluster",      "Match": { "Path": "/api/cart/{**catch-all}" } },
      "inventory-route":  { "ClusterId": "inventory-cluster", "Match": { "Path": "/api/inventory/{**catch-all}" } },
      "vendors-route":    { "ClusterId": "vendor-cluster",    "Match": { "Path": "/api/vendors/{**catch-all}" } },
      "search-route":     { "ClusterId": "search-cluster",    "Match": { "Path": "/api/search/{**catch-all}" } },
      "reviews-route":    { "ClusterId": "review-cluster",    "Match": { "Path": "/api/reviews/{**catch-all}" } },
      "discounts-route":  { "ClusterId": "discount-cluster",  "Match": { "Path": "/api/discounts/{**catch-all}" } },
      "coupons-route":    { "ClusterId": "discount-cluster",  "Match": { "Path": "/api/coupons/{**catch-all}" } },
      "media-route":      { "ClusterId": "media-cluster",     "Match": { "Path": "/api/media/{**catch-all}" } },
      "admin-route":      { "ClusterId": "admin-cluster",     "Match": { "Path": "/api/admin/{**catch-all}" } },
      "analytics-route":  { "ClusterId": "analytics-cluster", "Match": { "Path": "/api/analytics/{**catch-all}" } },
      "payouts-route":    { "ClusterId": "payout-cluster",    "Match": { "Path": "/api/payouts/{**catch-all}" } },
      "shipments-route":  { "ClusterId": "shipping-cluster",  "Match": { "Path": "/api/shipments/{**catch-all}" } }
    },
    "Clusters": {
      "identity-cluster":  { "Destinations": { "d1": { "Address": "http://localhost:5001" } } },
      "catalog-cluster":   { "Destinations": { "d1": { "Address": "http://localhost:5010" } } },
      "order-cluster":     { "Destinations": { "d1": { "Address": "http://localhost:5020" } } },
      "payment-cluster":   { "Destinations": { "d1": { "Address": "http://localhost:5030" } } },
      "cart-cluster":      { "Destinations": { "d1": { "Address": "http://localhost:5040" } } },
      "inventory-cluster": { "Destinations": { "d1": { "Address": "http://localhost:5050" } } },
      "vendor-cluster":    { "Destinations": { "d1": { "Address": "http://localhost:5060" } } },
      "search-cluster":    { "Destinations": { "d1": { "Address": "http://localhost:5070" } } },
      "review-cluster":    { "Destinations": { "d1": { "Address": "http://localhost:5080" } } },
      "discount-cluster":  { "Destinations": { "d1": { "Address": "http://localhost:5090" } } },
      "media-cluster":     { "Destinations": { "d1": { "Address": "http://localhost:5100" } } },
      "admin-cluster":     { "Destinations": { "d1": { "Address": "http://localhost:5110" } } },
      "analytics-cluster": { "Destinations": { "d1": { "Address": "http://localhost:5120" } } },
      "payout-cluster":    { "Destinations": { "d1": { "Address": "http://localhost:5130" } } },
      "shipping-cluster":  { "Destinations": { "d1": { "Address": "http://localhost:5140" } } }
    }
  }
}
